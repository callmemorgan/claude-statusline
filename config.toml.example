# claude-statusline example config.
# Copy to ~/.config/claude-statusline/config.toml and edit, or run
# `claude-statusline configure` to edit interactively.

schema_version = 1

# theme: built-in color palette.
#   classic (default) | catppuccin-mocha | nord | dracula | gruvbox-dark |
#   tokyo-night | newsprint | paper | solarized-light | monochrome
# "classic" is the original pre-1.0 16-color look ("original" works as an alias).
theme = "classic"

# color_depth: how colors are emitted. "auto" (default) detects from
# COLORTERM/TERM; set explicitly if your terminal is misdetected.
#   auto | truecolor | 256 | 16 | none
#color_depth = "auto"

# reflow: how segments wrap on narrow terminals. Wrapping is opt-in.
#   "off" (default) — no wrapping; long lines are left for the terminal to soft-wrap
#   "cascade"       — segments spill greedily across line boundaries
#   "group"         — each logical line wraps independently
#reflow = "cascade"

# preset: named layout used only when `segments` is absent.
#   classic | minimal | zen | cost-tracker | git-focus | vim-coder |
#   quota-watch | full-dashboard
#preset = "cost-tracker"

# Which segments to show, in order. Omit the key for the default set
# (plugins are auto-appended); use [] to hide everything.
segments = [
  "vim-mode",
  "sandbox",
  "session-name",
  "agent-state",
  "directory",
  "added-dirs",
  "git-branch",
  "artifact-count",
  "lines-changed",
  "cache-percent",
  "cost",
  "model",
  "output-style",
  "version",
  "update",
  "duration",
  "cost-rate",
  "api-efficiency",
  "tokens",
  "context-window",
  "rate-limit-5h",
  "rate-limit-7d",
  "plan-tier",
]

# Separator and padding between segments.
[style]
# separator: bar (default) | dot | slash | chevron | powerline | space | custom
separator = "bar"
#separator_custom = " ∘ "   # used when separator = "custom"
#padding = 1                # leading spaces per line

# Override individual theme roles. Values: #rrggbb hex, 0-255 index, or a
# 16-color name. Roles: model dir git changes duration cost dim ok warn crit
# agent vim accent session sep
#[theme_colors]
#git = "#a3be8c"
#dim = "245"

# Override which line (1-9) a segment renders on.
[lines]
cost = 1
model = 2
"context-window" = 3

# Override a segment's primary color.
# Values: #rrggbb hex, 0-255 index, theme role, or a 16-color name
# (red green yellow blue magenta cyan white + bright-* variants).
[colors]
model = "#cba6f7"
cost = "green"

# Per-segment settings. Open the TUI and press `o` on a segment to discover
# its settings interactively.
[settings.context-window]
bar_width = 30
iconset = "smooth"

# Rich git status (dirty marker + ahead/behind counts) is opt-in:
#[settings.git-branch]
#git_status = true

# Git stash count (⚑N) is an opt-in segment — add "git-stash" to segments above:
#[settings.git-stash]
#git_stash_ttl_sec = 10

# Session history store — powers $/h burn rates, →NN% rate-limit projections,
# and the context growth trend. Files live under
# ${XDG_STATE_HOME:-~/.local/state}/claude-statusline/sessions/.
[state]
enabled = true
retention_hours = 48

# Custom executable segments.
# Single-field plugin — whole stdout becomes the segment value:
[[plugins]]
id = "memory"
command = "~/.config/claude-statusline/plugins/memory.sh"
line = 1
desc = "RAM usage"
timeout_ms = 200

# Multi-field plugin — stdout is parsed as "key:value" lines, the command
# runs once per render regardless of field count:
#
# [[plugins]]
# command = "~/.config/claude-statusline/plugins/sysinfo.sh"
# timeout_ms = 200
#
#   [[plugins.fields]]
#   id = "cpu"
#   line = 1
#   desc = "CPU usage"
#
#   [[plugins.fields]]
#   id = "swap"
#   line = 2
#   desc = "Swap usage"

# Async plugin — never blocks the render; shows the last cached value and
# refreshes it in the background at most every refresh_ms. The cache is shared
# across sessions (keyed by command), so environment-level data is consistent.
# [[plugins]]
# id = "k8s-context"
# command = "~/.config/claude-statusline/plugins/k8s.sh"
# async = true
# refresh_ms = 10000   # consider cache stale after 10s
# timeout_ms = 8000    # kill the background run after 8s

# Post-upgrade announcement: after updating, the statusline shows the
# release notes for a short window, then returns to normal.
# [release_notes]
# announce = true
# duration_seconds = 25   # 0 disables the takeover entirely
# max_lines = 10          # 0 or "status-line" keeps the statusline's own height

# Update checking: "notify" shows an ⬆ segment when a new release exists,
# "auto" additionally installs it in the background (non-Homebrew, non-npm
# installs), "off" disables checks entirely (no network, ever).
# npm installs are excluded from "auto" to avoid fighting the package manager;
# update those with `npm update -g @morgan.rebrand/claude-statusline`.
# [update]
# mode = "notify"
# check_hours = 24
